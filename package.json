{
  "name": "fort-kitchen",
  "version": "0.1.0",
  "private": false,
  "description": "A forkable, agent-native kitchen operating system. Local-first; deploys to Cloudflare Workers.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "start": "node --experimental-strip-types src/server/local.ts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "node --experimental-strip-types --test tests/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240900.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
